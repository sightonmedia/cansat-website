---
// Deterministic LCG PRNG — same stars every build
let seed = 0x43F9D219;
const rand = () => {
  seed = (Math.imul(seed, 1664525) + 1013904223) | 0;
  return (seed >>> 0) / 0xFFFFFFFF;
};
const stars = Array.from({ length: 200 }, () => ({
  cx: (rand() * 100).toFixed(2),
  cy: (rand() * 100).toFixed(2),
  r:  rand() > 0.92 ? '1.6' : rand() > 0.76 ? '1.0' : '0.55',
  o:  (0.12 + rand() * 0.65).toFixed(2),
}));
---
<div class="starfield" aria-hidden="true">
  <svg
    viewBox="0 0 100 100"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    {stars.map(s => (
      <circle
        cx={s.cx}
        cy={s.cy}
        r={s.r}
        fill="white"
        opacity={s.o}
      />
    ))}
  </svg>
</div>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .starfield svg {
    width: 100%;
    height: 100%;
  }
</style>
