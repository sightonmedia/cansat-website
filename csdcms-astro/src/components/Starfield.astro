---
// Canvas starfield: three parallax depth layers with a gentle twinkle and a
// faint response to pointer movement. Deterministic LCG so the field looks
// the same on every visit. Falls back to a single static frame when the
// visitor prefers reduced motion.
---
<canvas class="starfield" aria-hidden="true"></canvas>

<script is:inline>
(() => {
  const canvas = document.querySelector('.starfield');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  // Deterministic LCG — same stars every visit
  let seed = 0x43F9D219;
  const rand = () => {
    seed = (Math.imul(seed, 1664525) + 1013904223) | 0;
    return (seed >>> 0) / 0xFFFFFFFF;
  };

  // depth layers: far → near (parallax factor, pointer shift, size, count)
  const LAYERS = [
    { scroll: 0.02, mouse: 2, rMin: 0.4, rMax: 0.8, count: 120, alpha: 0.55 },
    { scroll: 0.05, mouse: 5, rMin: 0.7, rMax: 1.2, count: 70,  alpha: 0.75 },
    { scroll: 0.09, mouse: 8, rMin: 1.1, rMax: 1.9, count: 30,  alpha: 0.95 },
  ];
  const stars = [];
  LAYERS.forEach((layer, li) => {
    for (let i = 0; i < layer.count; i++) {
      stars.push({
        layer: li,
        x: rand(),
        y: rand(),
        r: layer.rMin + rand() * (layer.rMax - layer.rMin),
        base: 0.25 + rand() * layer.alpha * 0.75,
        phase: rand() * Math.PI * 2,
        speed: 0.4 + rand() * 0.9,
      });
    }
  });

  let w = 0, h = 0, dpr = 1;
  const resize = () => {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = window.innerWidth;
    h = window.innerHeight;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  };
  resize();

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // pointer offset, eased so the field drifts rather than snaps
  let mx = 0, my = 0, tmx = 0, tmy = 0;

  const wrap = (v, max) => ((v % max) + max) % max;

  const draw = (t) => {
    ctx.clearRect(0, 0, w, h);
    const scrollY = window.scrollY || 0;
    ctx.fillStyle = '#fff';
    for (const s of stars) {
      const L = LAYERS[s.layer];
      const px = wrap(s.x * w + mx * L.mouse, w);
      const py = wrap(s.y * h - scrollY * L.scroll + my * L.mouse * 0.6, h);
      const tw = reduced ? 1 : 1 + 0.2 * Math.sin(t * 0.001 * s.speed + s.phase);
      ctx.globalAlpha = Math.max(0.05, Math.min(1, s.base * tw));
      ctx.beginPath();
      ctx.arc(px, py, s.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  };

  if (reduced) {
    // one static frame; re-render only on resize
    draw(0);
    window.addEventListener('resize', () => { resize(); draw(0); });
    return;
  }

  window.addEventListener('resize', resize);
  window.addEventListener('pointermove', (e) => {
    tmx = (e.clientX / w - 0.5) * 2;
    tmy = (e.clientY / h - 0.5) * 2;
  }, { passive: true });

  let rafId = 0;
  const loop = (t) => {
    mx += (tmx - mx) * 0.04;
    my += (tmy - my) * 0.04;
    draw(t);
    rafId = requestAnimationFrame(loop);
  };
  rafId = requestAnimationFrame(loop);

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(rafId);
    } else {
      rafId = requestAnimationFrame(loop);
    }
  });
})();
</script>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
