---
import Layout from '../layouts/Layout.astro';
import BgPhoto from '../components/BgPhoto.astro';
import { SPACE_PHOTOS, SUPPORTER_LOGOS } from '../lib/images';

const reasons = [
  { title: 'Registration & eligibility', desc: 'Wondering if your school qualifies, or whether late registration is possible — ask directly.' },
  { title: 'Sponsorship & partnership', desc: 'If your organisation supports student STEM programmes, we’d like to hear from you.' },
  { title: 'Media & press', desc: 'Covering student-built satellites in Canada? We can connect you with teams and board members.' },
  { title: 'Volunteering', desc: 'Judges, mentors, and launch-day crew keep the Challenge flying — let us know if you’d like to help.' },
];
---
<Layout title="Contact" currentPage="/contact" description="Get in touch with CSDCMS — registration, sponsorship, media and volunteering enquiries.">

  <!-- ── PAGE HEADER ───────────────────────────────────── -->
  <section class="page-header s-nebula">
    <BgPhoto src={SPACE_PHOTOS.starTexture} variant="header" objectPosition="center" />
    <div class="container reveal">
      <h1>Contact Us</h1>
      <p>We're a small volunteer team, so replies usually take a few business days — a little longer during launch season.</p>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────────── -->
  <section class="section s-deep">
    <div class="container">
      <div class="contact-layout">

        <div class="card reveal">
          <span class="tag tag--signal mb-4">Program contact</span>
          <h2 class="contact-name">Lawrence Reeves</h2>
          <div class="contact-fields">
            <div class="contact-field">
              <span class="label">Email</span>
              <a href="mailto:info@csdcms.ca">info@csdcms.ca</a>
            </div>
            <div class="contact-field">
              <span class="label">Phone</span>
              <a href="tel:+17789886343">+1 778-988-6343</a>
            </div>
          </div>
          <p class="contact-note">If a reply takes longer than expected during launch season, don't worry — we'll always get back to you.</p>
        </div>

        <div class="card reveal">
          <h3 style="font-size:1.1rem;" class="mb-3">Common reasons to get in touch</h3>
          <ul class="numbered-list">
            {reasons.map((r, i) => (
              <li>
                <span class="num">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h4>{r.title}</h4>
                  <p>{r.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ── SUPPORTERS ─────────────────────────────────────── -->
  <section class="section s-cosmos">
    <div class="container">
      <div class="section-head reveal">
        <h2>Mission partners</h2>
        <p>The CSDCMS thanks the following organisations for their support.</p>
      </div>
      <div class="supporters-grid reveal">
        {SUPPORTER_LOGOS.map(logo => (
          <div class="supporters-tile"><img src={logo.src} alt={logo.alt} loading="lazy"></div>
        ))}
      </div>
    </div>
  </section>

</Layout>
