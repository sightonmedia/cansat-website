---
import Layout from '../layouts/Layout.astro';
import BgPhoto from '../components/BgPhoto.astro';
import { SPACE_PHOTOS, CANSAT_PHOTO, SUPPORTER_LOGOS } from '../lib/images';
---
<Layout title="Home" currentPage="/">

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="section hero s-void">
    <div class="hero__bg" aria-hidden="true">
      <BgPhoto src={SPACE_PHOTOS.blueMarble} variant="hero" objectPosition="65% 45%" />
    </div>
    <div class="hero__stage container">
      <div class="hero__scene hero__scene--headline" aria-label="Design it. Build it. Launch it.">
        <h1 class="hero__headline">
          <span>Design it.</span>
          <span>Build it.</span>
          <em>Launch&nbsp;it.</em>
        </h1>
      </div>

      <div class="hero__scene hero__scene--mission">
        <div class="hero__content">
          <div class="eyebrow">CanSat Design Challenge · 2025–26</div>
          <p class="hero__desc">
            Every year, Canadian high school teams design, build, and fly a real
            atmospheric science payload the size of a soft-drink can. It descends
            under a parachute the team made, and the data it collects is real.
          </p>
          <div class="hero__ctas">
            <a class="btn btn--primary btn--lg" href="/challenge">Explore the Challenge</a>
            <a class="btn btn--ghost btn--lg" href="/resources">View Resources</a>
          </div>
        </div>

        <!-- CanSat launch graphic -->
        <div class="hero__visual" aria-hidden="true">
        <svg class="hero__svg" viewBox="0 0 560 460" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Radar rings from implied Earth below -->
          <circle cx="280" cy="680" r="440" fill="none" stroke="white" stroke-width="1" opacity=".035"/>
          <circle cx="280" cy="680" r="580" fill="none" stroke="white" stroke-width="1" opacity=".022"/>
          <circle cx="280" cy="680" r="700" fill="none" stroke="white" stroke-width="1" opacity=".014"/>

          <!-- Inner (beginner) orbit arc -->
          <path d="M 60 430 Q 130 210 280 175 Q 430 210 500 430"
            fill="none" stroke="#4f7bdc" stroke-width="1" stroke-dasharray="5 9" opacity=".35"/>

          <!-- Outer (advanced) orbit arc -->
          <path d="M -20 440 Q 60 80 280 38 Q 500 80 580 440"
            fill="none" stroke="#59dff3" stroke-width="1.2" stroke-dasharray="7 11" opacity=".42"/>

          <!-- Trajectory trail (already flown) -->
          <path d="M 280 38 Q 160 70 80 190"
            fill="none" stroke="#4ed8f0" stroke-width="1.5" stroke-dasharray="2 7" opacity=".55"/>

          <!-- ── ADVANCED: rocket launch to 1 km, dropping a CanSat ── -->
          <g class="hero-rocket" transform="translate(330,52)">
            <path d="M0,-26 C5,-18 8,-8 8,0 L-8,0 C-8,-8 -5,-18 0,-26 Z" fill="#cfe9f5" stroke="#59dff3" stroke-width="1"/>
            <rect x="-8" y="0" width="16" height="22" fill="#0d1e38" stroke="#59dff3" stroke-width="1.2"/>
            <circle cx="0" cy="9" r="3.4" fill="#59dff3" opacity=".5"/>
            <path d="M-8,14 L-19,27 L-8,22 Z" fill="#4ed8f0" opacity=".85"/>
            <path d="M8,14 L19,27 L8,22 Z" fill="#4ed8f0" opacity=".85"/>
            <path class="hero-rocket__flame" d="M-5,22 Q0,35 0,42 Q0,35 5,22 Z" fill="#f06030" opacity=".85"/>
          </g>
          <text x="352" y="34" class="hero-altitude-label hero-altitude-label--advanced">1 KM · ROCKET</text>

          <g class="hero-fall hero-fall--rocket">
            <g class="hero-parachute">
              <path d="M306,90 C306,72 354,72 354,90 Z" fill="none" stroke="#59dff3" stroke-width="1.4"/>
              <path d="M306,90 Q330,98 354,90" fill="none" stroke="#59dff3" stroke-width="1" opacity=".6"/>
              <line x1="306" y1="90" x2="324" y2="108" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
              <line x1="330" y1="88" x2="330" y2="108" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
              <line x1="354" y1="90" x2="336" y2="108" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
            </g>
            <rect x="324" y="108" width="12" height="18" rx="1.5" fill="#0d1e38" stroke="#59dff3" stroke-width="1.2"/>
            <rect x="324" y="112" width="12" height="3" fill="#59dff3" opacity=".25"/>
          </g>
          <ellipse class="hero-landing hero-landing--rocket" cx="330" cy="404" rx="15" ry="4" fill="#59dff3"/>

          <!-- ── BEGINNER: drone hover at 120 m, dropping a CanSat ── -->
          <g class="hero-drone" transform="translate(160,176)">
            <rect x="-10" y="-5" width="20" height="10" rx="3" fill="#0d1e38" stroke="#4f7bdc" stroke-width="1.2"/>
            <circle cx="0" cy="0" r="2" fill="#4f7bdc" opacity=".6"/>
            <line x1="-10" y1="-3" x2="-27" y2="-17" stroke="#4f7bdc" stroke-width="1.4"/>
            <line x1="10" y1="-3" x2="27" y2="-17" stroke="#4f7bdc" stroke-width="1.4"/>
            <line x1="-10" y1="3" x2="-27" y2="17" stroke="#4f7bdc" stroke-width="1.4"/>
            <line x1="10" y1="3" x2="27" y2="17" stroke="#4f7bdc" stroke-width="1.4"/>
            <g class="hero-drone__rotor" style="transform-origin:-27px -17px;"><circle cx="-27" cy="-17" r="7" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="-27" y1="-24" x2="-27" y2="-10" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
            <g class="hero-drone__rotor" style="transform-origin:27px -17px;"><circle cx="27" cy="-17" r="7" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="27" y1="-24" x2="27" y2="-10" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
            <g class="hero-drone__rotor" style="transform-origin:-27px 17px;"><circle cx="-27" cy="17" r="7" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="-27" y1="10" x2="-27" y2="24" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
            <g class="hero-drone__rotor" style="transform-origin:27px 17px;"><circle cx="27" cy="17" r="7" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="27" y1="10" x2="27" y2="24" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
          </g>
          <text x="198" y="148" class="hero-altitude-label hero-altitude-label--beginner">120 M · DRONE</text>

          <g class="hero-fall hero-fall--drone">
            <g class="hero-parachute">
              <path d="M136,202 C136,186 184,186 184,202 Z" fill="none" stroke="#4f7bdc" stroke-width="1.4"/>
              <path d="M136,202 Q160,210 184,202" fill="none" stroke="#4f7bdc" stroke-width="1" opacity=".6"/>
              <line x1="136" y1="202" x2="154" y2="220" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
              <line x1="160" y1="200" x2="160" y2="220" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
              <line x1="184" y1="202" x2="166" y2="220" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
            </g>
            <rect x="154" y="220" width="12" height="18" rx="1.5" fill="#0d1e38" stroke="#4f7bdc" stroke-width="1.2"/>
            <rect x="154" y="224" width="12" height="3" fill="#4f7bdc" opacity=".25"/>
          </g>
          <ellipse class="hero-landing hero-landing--drone" cx="160" cy="404" rx="15" ry="4" fill="#4f7bdc"/>

          <!-- Data callout panel -->
          <g transform="translate(360,52)">
            <rect x="0" y="0" width="168" height="78" fill="rgba(8,15,28,.85)" stroke="#59dff3" stroke-width=".6" opacity=".92"/>
            <path d="M0 0 L12 0 M0 0 L0 12" stroke="#59dff3" stroke-width="1.6"/>
            <path d="M168 78 L156 78 M168 78 L168 66" stroke="#59dff3" stroke-width="1.6"/>
            <text x="12" y="18" fill="#59dff3" font-family="monospace" font-size="7.5" letter-spacing="1.2" opacity=".7">STATUS</text>
            <text x="12" y="31" fill="#e8f2fc" font-family="monospace" font-size="10" font-weight="700">SEASON 2025–26</text>
            <line x1="12" y1="38" x2="156" y2="38" stroke="#59dff3" stroke-width=".5" opacity=".3"/>
            <text x="12" y="53" fill="#59dff3" font-family="monospace" font-size="7.5" letter-spacing="1.2" opacity=".7">CATEGORIES</text>
            <text x="12" y="67" fill="#e8f2fc" font-family="monospace" font-size="9.5">BEGINNER · ADVANCED</text>
          </g>

          <!-- Corner brackets -->
          <path d="M 16 16 L 42 16 M 16 16 L 16 42" stroke="#59dff3" stroke-width="1" opacity=".22"/>
          <path d="M 544 444 L 518 444 M 544 444 L 544 418" stroke="#59dff3" stroke-width="1" opacity=".22"/>
        </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHAT IS CANSAT (real hardware photo) ──────────── -->
  <section class="section s-cosmos">
    <div class="container">
      <div class="feature-split">
        <div class="reveal">
          <div class="eyebrow">The Mission</div>
          <h2 style="margin-bottom:var(--sp-5);">A real science instrument.<br>A real flight.</h2>
          <p style="font-size:1.1rem;">
            A CanSat is a small science payload (roughly 66 mm across and 115 mm tall) packed
            with sensors that record real atmospheric data during flight. You build the
            parachute. The flight is real. So is the data.
          </p>
        </div>
        <div class="feature-photo reveal">
          <img src={CANSAT_PHOTO} alt="A completed CanSat flight unit from the 2022 winning team, showing the onboard sensor board, antenna and battery wiring" loading="lazy">
          <div class="feature-photo__caption">
            <strong>Flight Unit — 2022</strong>
            Winning team's CanSat, fully assembled
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TWO PATHS ─────────────────────────────────────── -->
  <section class="section s-nebula" style="position:relative;overflow:hidden;">
    <BgPhoto src={SPACE_PHOTOS.andromeda} variant="header" objectPosition="center 30%" />
    <div class="container" style="position:relative;z-index:2;">
      <div class="section-head reveal">
        <div class="eyebrow">Choose your path</div>
        <h2>Two ways to fly</h2>
        <p>Both categories run the same core science mission. The difference is how high you go and how you get there.</p>
      </div>
      <div class="categories">
        <div class="cat-card cat-card--beginner reveal">
          <div class="cat-card__bg"></div>
          <div class="cat-card__head">
            <span class="cat-card__tag">Beginner</span>
            <svg class="cardicon" viewBox="0 0 120 120" aria-hidden="true">
              <g class="cardicon-drone">
                <rect x="48" y="22" width="24" height="12" rx="3.5" fill="#0d1e38" stroke="#4f7bdc" stroke-width="1.3"/>
                <circle cx="60" cy="28" r="2.4" fill="#4f7bdc" opacity=".6"/>
                <line x1="50" y1="25" x2="32" y2="12" stroke="#4f7bdc" stroke-width="1.6"/>
                <line x1="70" y1="25" x2="88" y2="12" stroke="#4f7bdc" stroke-width="1.6"/>
                <line x1="50" y1="31" x2="32" y2="44" stroke="#4f7bdc" stroke-width="1.6"/>
                <line x1="70" y1="31" x2="88" y2="44" stroke="#4f7bdc" stroke-width="1.6"/>
                <g class="cardicon-rotor" style="transform-origin:32px 12px;"><circle cx="32" cy="12" r="8" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="32" y1="4" x2="32" y2="20" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
                <g class="cardicon-rotor" style="transform-origin:88px 12px;"><circle cx="88" cy="12" r="8" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="88" y1="4" x2="88" y2="20" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
                <g class="cardicon-rotor" style="transform-origin:32px 44px;"><circle cx="32" cy="44" r="8" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="32" y1="36" x2="32" y2="52" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
                <g class="cardicon-rotor" style="transform-origin:88px 44px;"><circle cx="88" cy="44" r="8" fill="none" stroke="#59dff3" stroke-width="1" opacity=".55"/><line x1="88" y1="36" x2="88" y2="52" stroke="#59dff3" stroke-width="1" opacity=".8"/></g>
              </g>
              <g class="cardicon-fall cardicon-fall--drone">
                <g class="cardicon-parachute">
                  <path d="M42,68 C42,54 78,54 78,68 Z" fill="none" stroke="#4f7bdc" stroke-width="1.4"/>
                  <line x1="42" y1="68" x2="56" y2="84" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
                  <line x1="60" y1="66" x2="60" y2="84" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
                  <line x1="78" y1="68" x2="64" y2="84" stroke="#4f7bdc" stroke-width=".8" opacity=".7"/>
                </g>
                <rect x="54" y="84" width="12" height="17" rx="1.5" fill="#0d1e38" stroke="#4f7bdc" stroke-width="1.2"/>
                <rect x="54" y="88" width="12" height="3" fill="#4f7bdc" opacity=".25"/>
              </g>
              <ellipse class="cardicon-landing cardicon-landing--drone" cx="60" cy="106" rx="13" ry="3.4" fill="#4f7bdc"/>
            </svg>
          </div>
          <h3>Drone Drop</h3>
          <p>
            We supply a free CanSat kit. Your team assembles it, programs the sensors,
            and we drop it from a drone at about 120 metres. Real descent, real parachute
            you designed.
          </p>
          <a class="btn btn--ghost" href="/challenge" style="margin-top:auto;">Learn more →</a>
        </div>
        <div class="cat-card cat-card--advanced reveal">
          <div class="cat-card__bg" style="background-image:linear-gradient(rgba(78,216,240,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(78,216,240,0.04) 1px,transparent 1px);"></div>
          <div class="cat-card__head">
            <span class="cat-card__tag">Advanced</span>
            <svg class="cardicon" viewBox="0 0 120 120" aria-hidden="true">
              <g class="cardicon-rocket">
                <path d="M60,8 C66,16 69,26 69,34 L51,34 C51,26 54,16 60,8 Z" fill="#cfe9f5" stroke="#59dff3" stroke-width="1.2"/>
                <rect x="51" y="34" width="18" height="24" fill="#0d1e38" stroke="#59dff3" stroke-width="1.3"/>
                <circle cx="60" cy="44" r="3.6" fill="#59dff3" opacity=".5"/>
                <path d="M51,50 L38,64 L51,58 Z" fill="#4ed8f0" opacity=".85"/>
                <path d="M69,50 L82,64 L69,58 Z" fill="#4ed8f0" opacity=".85"/>
                <path class="cardicon-flame" d="M54,58 Q60,72 60,80 Q60,72 66,58 Z" fill="#f06030" opacity=".85"/>
              </g>
              <g class="cardicon-fall cardicon-fall--rocket">
                <g class="cardicon-parachute">
                  <path d="M38,76 C38,60 82,60 82,76 Z" fill="none" stroke="#59dff3" stroke-width="1.4"/>
                  <line x1="38" y1="76" x2="55" y2="92" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
                  <line x1="60" y1="74" x2="60" y2="92" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
                  <line x1="82" y1="76" x2="65" y2="92" stroke="#59dff3" stroke-width=".8" opacity=".7"/>
                </g>
                <rect x="54" y="92" width="12" height="17" rx="1.5" fill="#0d1e38" stroke="#59dff3" stroke-width="1.2"/>
                <rect x="54" y="96" width="12" height="3" fill="#59dff3" opacity=".25"/>
              </g>
              <ellipse class="cardicon-landing cardicon-landing--rocket" cx="60" cy="112" rx="13" ry="3.4" fill="#59dff3"/>
            </svg>
          </div>
          <h3>Rocket Launch</h3>
          <p>
            Your team travels to Lethbridge, Alberta. Your CanSat launches by
            sounding rocket to above 1 km, transmitting live telemetry all
            the way down. The top team goes to the ESA CanSat competition
            in the Netherlands.
          </p>
          <a class="btn btn--ghost" href="/challenge" style="margin-top:auto;">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FIELD NOTES (real mission photos) ─────────────── -->
  <section class="section s-deep">
    <div class="container">
      <div class="section-head reveal">
        <div class="eyebrow">Field notes</div>
        <h2>From last season's campaigns</h2>
        <p>Real teams, real builds, real launches. A few moments from the 2024–25 season.</p>
      </div>
      <div class="photolog reveal">
        <div class="photolog__item">
          <img src="https://www.csdcms.ca/Photos/FrontPage1.JPG" alt="CanSat Design Challenge team working on their satellite build" loading="lazy">
          <div class="photolog__caption"><span>Log 01</span><span>Build Day</span></div>
        </div>
        <div class="photolog__item">
          <img src="https://www.csdcms.ca/Photos/FrontPage2.JPG" alt="CanSat Design Challenge launch campaign in the field" loading="lazy">
          <div class="photolog__caption"><span>Log 02</span><span>Launch Day</span></div>
        </div>
        <div class="photolog__item">
          <img src="https://www.csdcms.ca/Photos/FrontPage3.JPG" alt="CanSat Design Challenge students with their finished satellite" loading="lazy">
          <div class="photolog__caption"><span>Log 03</span><span>Mission Complete</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MISSION STATEMENT (Earth image band) ──────────── -->
  <section class="image-band">
    <BgPhoto src={SPACE_PHOTOS.pillars} variant="band" objectPosition="center 35%" />
    <div class="container">
      <div class="image-band__content reveal">
        <div class="eyebrow" style="justify-content:center;">Why it matters</div>
        <blockquote style="font-family:var(--f-display);font-weight:800;font-size:clamp(1.6rem,3.5vw,2.6rem);text-transform:uppercase;line-height:1.05;letter-spacing:.02em;color:var(--star);margin-bottom:var(--sp-5);">
          "The best way to learn aerospace engineering is to actually do aerospace engineering."
        </blockquote>
        <p style="font-size:1.05rem;margin-inline:auto;">
          CSDCMS is a registered Canadian charity. Our job is to give high school
          students a real path into the space industry: actual hardware, actual launches,
          and real engineering problems to solve.
        </p>
        <div style="margin-top:var(--sp-6);display:flex;gap:var(--sp-3);justify-content:center;flex-wrap:wrap;">
          <a class="btn btn--primary btn--lg" href="/register">Register your team</a>
          <a class="btn btn--ghost" href="https://www.canadahelps.org/en/charities/canadian-satellite-design-challenge-management-society-inc/" target="_blank" rel="noopener">Support the mission</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SUPPORTERS ─────────────────────────────────────── -->
  <section class="section--sm s-cosmos">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <div class="eyebrow" style="justify-content:center;">Supported by</div>
        <h2>Our partners</h2>
      </div>
      <div class="supporters-grid reveal">
        {SUPPORTER_LOGOS.map(logo => (
          <div class="supporters-tile"><img src={logo.src} alt={logo.alt} loading="lazy"></div>
        ))}
      </div>
    </div>
  </section>

</Layout>
