---
import Layout from '../layouts/Layout.astro';
import BgPhoto from '../components/BgPhoto.astro';
import { SPACE_PHOTOS } from '../lib/images';
---
<Layout title="Register" currentPage="/register" description="Register your team for the CSDCMS CanSat Design Challenge. Check current registration status and learn what to expect.">

  <!-- ── PAGE HEADER ───────────────────────────────────── -->
  <section class="page-header s-nebula">
    <BgPhoto src={SPACE_PHOTOS.aurora} variant="header" objectPosition="center 60%" />
    <div class="container reveal">
      <h1>Register</h1>
      <p>Registration connects your school to the full CanSat programme, from kit delivery to launch day.</p>
    </div>
  </section>

  <!-- ── STATUS ────────────────────────────────────────── -->
  <section class="section s-deep">
    <div class="container">
      <div class="status-panel reveal">
        <span class="tag tag--closed">Closed</span>
        <div class="status-panel__text">
          <h3>Registration for 2025–26 has closed</h3>
          <p>Late registration is sometimes possible — get in touch and we'll see what we can do.</p>
        </div>
      </div>

      <div class="section-head reveal">
        <h2>How it works</h2>
        <p>We keep the paperwork short so you can get to building.</p>
      </div>
      <div class="reg-steps">
        <div class="reg-step reg-step--active reveal">
          <div class="reg-step__num">01 —</div>
          <h4>Submit your team</h4>
          <p>Tell us your school name, your supervising teacher, an estimated team size, and your chosen category (Beginner or Advanced).</p>
        </div>
        <div class="reg-step reveal">
          <div class="reg-step__num">02 —</div>
          <h4>Receive confirmation</h4>
          <p>We confirm your spot. Beginner teams get kit delivery sorted; Advanced teams receive the requirements document and their preliminary design brief.</p>
        </div>
        <div class="reg-step reveal">
          <div class="reg-step__num">03 —</div>
          <h4>Build season begins</h4>
          <p>Work through the tutorial series, build your CanSat, iterate on your secondary experiment, and design the parachute system. The build season runs November through March.</p>
        </div>
        <div class="reg-step reveal">
          <div class="reg-step__num">04 —</div>
          <h4>Launch day</h4>
          <p>Come to your launch campaign. Beginner teams go to a regional site; Advanced teams travel to Lethbridge, Alberta. Fly, recover, analyse, present.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHICH CATEGORY ────────────────────────────────── -->
  <section class="section s-cosmos">
    <div class="container">
      <div class="section-head reveal">
        <h2>Beginner or Advanced?</h2>
        <p>Both are worth a season of your time. Pick the one that matches where your team is now.</p>
      </div>
      <div class="compare reveal">
        <div class="compare__col compare__col--beginner">
          <span class="tag tag--exhaust">Beginner</span>
          <h3>A good starting point if…</h3>
          <ul>
            <li>Your team has little or no electronics experience</li>
            <li>You want a guided introduction to embedded systems, with a kit to start from</li>
            <li>Your school can't fund travel to Lethbridge</li>
            <li>This is your team's first year in the Challenge</li>
          </ul>
        </div>
        <div class="compare__col compare__col--advanced">
          <span class="tag tag--signal">Advanced</span>
          <h3>A good fit if…</h3>
          <ul>
            <li>Your team has electronics and programming experience</li>
            <li>You want to design your own PCB from scratch</li>
            <li>You want to compete at the national level</li>
            <li>You want a shot at representing Canada at the ESA competition</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="section s-nebula">
    <div class="container">
      <div class="center-col reveal">
        <h2 class="mb-4">Questions before you register?</h2>
        <p class="lead">Categories, eligibility, what a launch day actually looks like — ask us. We're a small team and we answer every message.</p>
        <div class="cta-row cta-row--center mt-6">
          <a class="btn btn--primary btn--lg" href="/contact">Contact us</a>
          <a class="btn btn--ghost" href="/challenge">Read the full brief</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
