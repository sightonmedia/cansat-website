---
import Layout from '../layouts/Layout.astro';
import BgPhoto from '../components/BgPhoto.astro';
import { SPACE_PHOTOS } from '../lib/images';

const experiments = [
  { title: 'Atmospheric gas sensors', desc: 'Mapping CO₂ and VOC concentrations through the flight profile — how air chemistry changes with altitude during ascent and descent.' },
  { title: 'IMU & vibration analysis', desc: 'Six-axis IMUs recording the mechanical forces on a CanSat through launch, ejection, and deployment. Useful data for future teams designing their own hardware.' },
  { title: 'Descent cameras', desc: 'Downward cameras capturing the full descent on video — verifying parachute deployment, measuring drift, and producing aerial footage of the recovery area.' },
  { title: 'Deployable mini-drones', desc: 'One team flew a foldable micro-quadrotor that deployed after ejection and stabilised for independent flight before the CanSat touched down.' },
  { title: 'UV & particulate sensing', desc: 'Measuring UV-B radiation and PM2.5 particulate levels at altitude to build a vertical air-quality profile above the launch site.' },
  { title: 'Custom RF link design', desc: 'Some Advanced teams skip the off-the-shelf radio module entirely and build their own link, including custom PCB antennas and ground-station software.' },
];

const timeline = [
  { month: 'Sep',     title: 'Registration opens', desc: 'Teams submit their school info and choose Beginner or Advanced. Beginner teams get kit confirmation; Advanced teams start preliminary design.' },
  { month: 'Oct–Nov', title: 'Kit delivery & build start', desc: 'Beginner kits ship. Teams start on the tutorial series, set up their build environment, and get hands on hardware.' },
  { month: 'Nov–Mar', title: 'Build season', desc: 'The main build phase. Teams refine their hardware, write and test firmware, nail down their secondary experiment, and work out the parachute.' },
  { month: 'Apr–May', title: 'Beginner launch campaigns', desc: 'Beginner teams come out for their regional launch. CanSats are flight-checked, loaded under the drone, dropped, recovered, and the data is reviewed on the spot.' },
  { month: 'May–Jun', title: 'Advanced launch — Lethbridge, AB', desc: 'Advanced teams travel to the launch site, set up their ground stations, and fly. The top team is announced and prepares for ESA.' },
];
---
<Layout title="The Challenge" currentPage="/challenge" description="Everything about the CanSat Design Challenge — Beginner and Advanced categories, the science mission, and what past teams have built.">

  <!-- ── PAGE HEADER ───────────────────────────────────── -->
  <section class="page-header s-nebula">
    <BgPhoto src={SPACE_PHOTOS.cosmicCliffs} variant="header" objectPosition="center 35%" />
    <div class="container reveal">
      <h1>The CanSat Challenge</h1>
      <p>Two categories, one science mission, and a full season of engineering work. Here's what every team builds, and what the best teams earn.</p>
    </div>
  </section>

  <!-- ── THE SCIENCE MISSION ───────────────────────────── -->
  <section class="section s-deep">
    <div class="container">
      <div class="section-head reveal">
        <h2>The science mission</h2>
        <p>Beginner and Advanced teams carry the same core payload. Your CanSat must measure, record and return the following data from its flight.</p>
      </div>
      <div class="grid-2">
        <div class="card reveal">
          <span class="tag tag--signal mb-4">Required</span>
          <h3 class="mb-4">Primary Payload</h3>
          <dl class="spec-list">
            <div class="spec-row"><dt>Sensor</dt><dd>BMP-280 or equivalent</dd></div>
            <div class="spec-row"><dt>Measurement 1</dt><dd>Air pressure (hPa)</dd></div>
            <div class="spec-row"><dt>Measurement 2</dt><dd>Temperature (°C)</dd></div>
            <div class="spec-row"><dt>Optional</dt><dd>Relative humidity (%)</dd></div>
            <div class="spec-row"><dt>Sampling rate</dt><dd>≥ 1 Hz throughout flight</dd></div>
          </dl>
        </div>
        <div class="card reveal">
          <span class="tag tag--signal mb-4">Required</span>
          <h3 class="mb-4">Secondary Experiment</h3>
          <p class="mb-4">Every team also designs and carries an experiment of its own. The subject is up to you. Past teams have flown:</p>
          <ul class="bullet-list">
            <li>Gas / CO₂ concentration sensors</li>
            <li>Multi-axis accelerometers and gyroscopes</li>
            <li>Downward-facing camera systems</li>
            <li>Deployable mini-drones or gliders</li>
            <li>UV / particulate matter sensors</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BEGINNER ──────────────────────────────────────── -->
  <section class="section s-cosmos">
    <div class="container">
      <div class="grid-2-wide">
        <div class="reveal">
          <div class="cat-card cat-card--beginner cat-card--page cat-card--fill">
            <span class="cat-card__tag">Category 01</span>
            <h3>Beginner</h3>
            <dl class="spec-list">
              <div class="spec-row"><dt>Launch vehicle</dt><dd>Multirotor drone</dd></div>
              <div class="spec-row"><dt>Release altitude</dt><dd>~120 m AGL</dd></div>
              <div class="spec-row"><dt>Data return</dt><dd>On-board SD card</dd></div>
              <div class="spec-row"><dt>Kit supplied</dt><dd>Yes — free of charge</dd></div>
              <div class="spec-row"><dt>Location</dt><dd>TBD per season</dd></div>
            </dl>
          </div>
        </div>
        <div class="reveal">
          <h2 class="mb-5">Drone Drop</h2>
          <p>The Beginner category is open to any high school team — no electronics experience needed. CSDCMS supplies a free kit (PCB, sensor breakout boards, SD card logger, and the structural can) so your team can focus on learning, building, and programming rather than sourcing components.</p>
          <p>On launch day, your CanSat hangs beneath a drone and rides up to about 120 metres. It drops, descends under the parachute you sized and sewed, and lands. You recover it, pull the data, and present your findings.</p>
          <p>The CSDCMS tutorial series walks you through the full build — twelve chapters from first Arduino sketch to parachute sizing.</p>
          <div class="mt-6">
            <a class="btn btn--ghost" href="/resources">View tutorial series →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ADVANCED ──────────────────────────────────────── -->
  <section class="section s-nebula">
    <div class="container">
      <div class="grid-2-wide">
        <div class="reveal">
          <h2 class="mb-5">Rocket Launch</h2>
          <p>In the Advanced category, your team designs and builds its own CanSat from scratch. No kit. Your payload launches by sounding rocket to over 1 km above the ground at the annual campaign in Lethbridge, Alberta.</p>
          <p>During descent, your CanSat transmits live telemetry to a ground station your team designed and built. That means RF engineering — link budgets, antenna selection, modulation choices — with onboard SD logging as backup.</p>
          <p>The top Advanced team goes on to the ESA CanSat competition in the Netherlands, flying alongside the winning teams from across Europe.</p>
          <div class="mt-6">
            <a class="btn btn--signal" href="/register">Register for Advanced →</a>
          </div>
        </div>
        <div class="reveal">
          <div class="cat-card cat-card--advanced cat-card--page cat-card--fill">
            <span class="cat-card__tag">Category 02</span>
            <h3>Advanced</h3>
            <dl class="spec-list">
              <div class="spec-row"><dt>Launch vehicle</dt><dd>Sounding rocket</dd></div>
              <div class="spec-row"><dt>Apogee</dt><dd>1 km+ AGL</dd></div>
              <div class="spec-row"><dt>Data return</dt><dd>Live RF telemetry + SD</dd></div>
              <div class="spec-row"><dt>Kit supplied</dt><dd>No — team designs PCB</dd></div>
              <div class="spec-row"><dt>Location</dt><dd>Lethbridge, Alberta</dd></div>
              <div class="spec-row"><dt>Top prize</dt><dd>ESA CanSat, Netherlands</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── LAUNCH DAY (image band) ───────────────────────── -->
  <section class="image-band" style="padding-block:clamp(72px,10vw,120px);">
    <BgPhoto src={SPACE_PHOTOS.rocketLaunch} variant="band" objectPosition="center 30%" />
    <div class="container">
      <div class="image-band__content reveal">
        <h2 style="font-size:clamp(1.8rem,3.5vw,2.8rem);" class="mb-4">Launch day, Lethbridge</h2>
        <p>Advanced CanSats ride a sounding rocket past 1 km over the prairie, then come home by parachute.</p>
      </div>
    </div>
  </section>

  <!-- ── WHAT TEAMS HAVE BUILT ─────────────────────────── -->
  <section class="section s-deep">
    <div class="container">
      <div class="section-head reveal">
        <h2>Secondary experiments teams have flown</h2>
        <p>The secondary experiment is yours to define. These are the kinds of payloads Canadian teams have brought to the launchpad.</p>
      </div>
      <ul class="numbered-list numbered-list--2col reveal">
        {experiments.map((e, i) => (
          <li>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h4>{e.title}</h4>
              <p>{e.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── SEASON TIMELINE ───────────────────────────────── -->
  <section class="section s-cosmos">
    <div class="container">
      <div class="section-head reveal">
        <h2>From registration to launch</h2>
      </div>
      <div class="timeline">
        {timeline.map(t => (
          <div class="timeline__row reveal">
            <div class="timeline__month"><span class="timeline__label">{t.month}</span></div>
            <div class="timeline__content">
              <h4>{t.title}</h4>
              <p>{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ROW ───────────────────────────────────────── -->
  <section class="section--sm s-nebula">
    <div class="container split-row">
      <div class="reveal">
        <h2 style="font-size:clamp(1.6rem,3vw,2.4rem);">Ready to fly?</h2>
      </div>
      <div class="cta-row reveal">
        <a class="btn btn--primary btn--lg" href="/register">Register</a>
        <a class="btn btn--ghost btn--lg" href="/resources">Resources</a>
      </div>
    </div>
  </section>

</Layout>
